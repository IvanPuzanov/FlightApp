# Fastlane automates xcodebuild commands behind named "lanes".
# Run from the project root: bundle exec fastlane <lane_name>
#
# This project is generated by Tuist, so every lane starts with `tuist generate`.

default_platform(:ios)

PROJECT_ROOT = File.expand_path("..", __dir__)
WORKSPACE = File.join(PROJECT_ROOT, "FlightDemoApp.xcworkspace")
APP_SCHEME = "FlightDemoApp"
TEST_SCHEME = "Tests"
DEFAULT_TEST_PLAN = "UnitTests"
DEFAULT_DEVICE = "iPhone 16 Pro"

platform :ios do
  before_all do
    generate_project
  end

  desc "Generate the Xcode workspace via Tuist"
  lane :generate do
    generate_project
  end

  desc "Compile the app (build verification)"
  lane :build do |options|
    device = options[:device] || ENV["DEVICE"]
    destination = device ? "platform=iOS Simulator,name=#{device}" : "generic/platform=iOS Simulator"

    build_app(
      workspace: WORKSPACE,
      scheme: APP_SCHEME,
      skip_package_ipa: true,
      skip_archive: true,
      destination: destination,
      sdk: "iphonesimulator",
      clean: options[:clean] || false
    )
  end

  desc "Run tests from a Test Plan (default: UnitTests)"
  lane :test do |options|
    test_plan = options[:testplan] || ENV["TEST_PLAN"] || DEFAULT_TEST_PLAN
    device = options[:device] || ENV["DEVICE"] || DEFAULT_DEVICE

    ENV["FASTLANE_SKIP_UPDATE_DOCS"] = "true"
    register_test_artifact_cleanup

    scan(
      workspace: WORKSPACE,
      scheme: TEST_SCHEME,
      testplan: test_plan,
      device: device,
      clean: options[:clean] || false,
      code_coverage: false,
      result_bundle: false,
      output_types: "",
      output_files: "",
      suppress_xcode_output: true
    )
  end

  private_lane :generate_project do
    Dir.chdir(PROJECT_ROOT) do
      sh("tuist generate --no-open")
    end
  end

  def self.register_test_artifact_cleanup
    return if @test_artifact_cleanup_registered

    @test_artifact_cleanup_registered = true
    at_exit do
      %w[report.xml README.md Preview.html].each do |file|
        path = File.join(PROJECT_ROOT, "fastlane", file)
        File.delete(path) if File.exist?(path)
      end

      test_output = File.join(PROJECT_ROOT, "fastlane/test_output")
      FileUtils.rm_rf(test_output) if File.directory?(test_output)
    end
  end
end
